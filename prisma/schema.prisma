// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Model for Area-Based Traffic Summary
model TrafficSummary {
  id          String   @id @default(cuid())
  areaName    String
  routeName   String
  condition   String
  description String?
  reportCount Int      @default(0)
  severity    Int      @default(1)
  lastUpdated DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([areaName])
  @@index([condition])
}

// Model for Incident Report System
model Incident {
  id          String   @id @default(cuid())
  title       String
  description String
  type        String
  location    String
  latitude    Float?
  longitude   Float?
  photoUrl    String?
  status      String   @default("Active")
  reportedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model ParkingSpot {
  id             String   @id @default(cuid())
  ownerId        String
  location       String
  address        String
  additionalInfo String?
  lastUpdated    DateTime @default(now()) @updatedAt
  createdAt      DateTime @default(now())
}



model ServiceRequest {
  id          String   @id @default(cuid())
  userName    String
  contactInfo String
  issueType   String
  location    String
  status      String   @default("SEARCHING") // SEARCHING, MATCHED, COMPLETED
  createdAt   DateTime @default(now())
}

// The Mechanics/Garages available in Dhaka

model ServiceProvider {
  id          String   @id @default(cuid())
  name        String
  phone       String
  // We add @default so the 15 old rows don't crash
  specialty   String   @default("General Mechanic") 
  location    String   @default("Unknown")
  isAvailable Boolean  @default(true)
  rating      Float    @default(4.0)
}